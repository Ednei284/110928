{
  "name": "node-prisma-auth",
  "version": "1.0.0",
  "description": "API com autenticação e CRUD usando Prisma 6",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --exec node src/server.js",
    "postinstall": "prisma generate --no-engine",
    "deploy": "vercel --prod"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "@supabase/supabase-js": "^2.95.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^3.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^150.0.1",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^9.0.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^6.11.1",
    "supabase": "^2.76.9",
    "vercel": "^55.0.0"
  },
  "allowScripts": {
    "prisma@6.19.3": true,
    "sharp@0.34.5": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.27.0": true
  }
}